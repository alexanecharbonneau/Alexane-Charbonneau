---
// NavBar/Component, Style=Header — bord à bord du viewport, fixe.
// Le contenu interne reste centré dans la colonne 1024px (.navbar__inner).
---
<header class="navbar">
  <div class="navbar__inner">
    <a class="navbar__nametag" href="/" data-cursor-hover>
      <p class="label-nametag" style="margin:0;">Alexane Charbonneau</p>
    </a>
    <nav class="navbar__tabs">
      <a class="navbar__tab" href="/projets"><span class="label">Portfolio</span></a>
      <a class="navbar__tab" href="/curriculum"><span class="label">Curriculum</span></a>
      <a class="navbar__tab" href="mailto:alexanecharbonneau@gmail.com">
        <span class="label">Contact</span>
        <img class="navbar__tab-icon" src="/assets/svg/arrow-small-diag.svg" alt="" />
      </a>
    </nav>
  </div>
</header>
